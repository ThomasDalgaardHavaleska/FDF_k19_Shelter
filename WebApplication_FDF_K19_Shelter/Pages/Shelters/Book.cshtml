@page "{id:int}"
@model ShelterBookModel

<h2>Book @Model.Shelter.Name</h2>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">
        @Model.ErrorMessage
    </div>
}

<form method="post">
    <input type="hidden" asp-for="Shelter.ShelterId" />

    <div asp-validation-summary="All" class="validation-summary"></div>

    <div>
        <label asp-for="FullName">Full name</label>
        <input asp-for="FullName" />
        <span asp-validation-for="FullName" class="field-validation"> </span>
    </div>
    <div>
        <label asp-for="NoOfCampers">Number of campers</label>
        <input asp-for="NoOfCampers" type="number" required/>
        <span asp-validation-for="NoOfCampers" class="field-validation"></span>
    </div>
    <div>
        <label asp-for="CheckInDate">Check-in</label>
        <input asp-for="CheckInDate" type="datetime-local" required />
        <span asp-validation-for="CheckInDate" class="field-validation"></span>
    </div>
    <div>
        <label asp-for="CheckOutDate">Check-out</label>
        <input asp-for="CheckOutDate" type="datetime-local" required />
        <span asp-validation-for="CheckOutDate" class="field-validation"></span>
    </div>

    <div>
        <label>District</label>
        <select asp-for="SelectedDistrictId" id="districtSelect">
            <option value="">-- Select district --</option>
            @if (Model.AllDistricts != null)
            {
                foreach (var d in Model.AllDistricts)
                {
                    var ag = string.Join(',', d.AgeGroup ?? new List<string>());
                    <option value="@d.DistrictId" data-agegroups="@ag">@d.Name</option>
                }
            }
        </select>
        <span asp-validation-for="SelectedDistrictId" class="field-validation"></span>
    </div>

    <div>
        <label>Age group</label>
        <select asp-for="SelectedAgeGroup" id="ageGroupSelect">
            <option value="">-- Select age group --</option>
        </select>
        <span asp-validation-for="SelectedAgeGroup" class="field-validation"></span>
    </div>


    <button type="submit">Book</button>
</form>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

<script>
    $(function () {
        $('#districtSelect').on('change', function () {
            var selected = $(this).find('option:selected');
            var raw = selected.data('agegroups') || '';
            var ageGroups = raw === '' ? [] : String(raw).split(',');
            var $age = $('#ageGroupSelect');
            $age.empty();
            $age.append($('<option>').val('').text('-- Select age group --'));
            ageGroups.forEach(function (g) {
                if (g && g.trim().length > 0) {
                    $age.append($('<option>').val(g).text(g));
                }
            });
        });
    });
</script>

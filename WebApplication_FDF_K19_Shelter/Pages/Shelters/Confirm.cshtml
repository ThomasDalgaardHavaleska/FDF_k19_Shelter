@page "{id:int}"
@model ShelterConfirmModel

<h2>Booking Confirmed</h2>
<p>Booking id: @Model.Booking.BookingId</p>
<p>Full name: @Model.Booking.FullName</p>
<p>Shelter: @Model.Booking.ShelterToBook.Name</p>
<p>Check-in: @Model.Booking.CheckInDate</p>
<p>Check-out: @Model.Booking.CheckoutDate</p>
<p><a asp-page="/Shelters/Index">Back to list</a></p>